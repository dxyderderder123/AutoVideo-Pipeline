# =============================================================================
# 功能开关 (Feature Toggles)
# =============================================================================
# 这些开关控制主要功能，0=关闭，1=开启

# 上传开关 - 导师测试时务必保持关闭(0)，避免误传！
ENABLE_UPLOAD=0

# 快速模式 - 开启后TTS使用更少推理步数，速度快但质量略降
FAST_MODE=0

# 预览模式 - 开启后生成480p低质量视频，用于快速验证流程
PREVIEW_MODE=0

# =============================================================================
# API Keys Configuration
# =============================================================================

# DeepSeek API Key (用于文本分析和翻译)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Pexels API Key (用于视频素材搜索)
PEXELS_API_KEY=your_pexels_api_key_here

# Pixabay API Key (用于视频素材搜索 - 补充)
PIXABAY_API_KEY=your_pixabay_api_key_here

# SiliconCloud API Key (用于封面生成 - 免费 Kolors 模型)
SILICON_CLOUD_API_KEY=your_siliconcloud_api_key_here

# =============================================================================
# Bilibili 上传配置 (本地测试可留空)
# =============================================================================
BILIBILI_RAW_COOKIE=your_raw_cookie_here
BILIBILI_SESSDATA=your_sessdata_here
BILIBILI_BILI_JCT=your_bili_jct_here
BILIBILI_BUVID3=your_buvid3_here
BILIBILI_DEDEUSERID=your_dedeuserid_here
